<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
   <xs:simpleType name="helpFormat">
      <xs:restriction base="xs:string">
         <xs:enumeration value="swing"/>
         <xs:enumeration value="javaFX"/>
      </xs:restriction>
   </xs:simpleType>   
   <xs:complexType name="database">
      <xs:sequence>
         <xs:element maxOccurs="unbounded" minOccurs="0" name="styleSheetThemes" type="styleSheetTheme" />
         <xs:element maxOccurs="1" minOccurs="0" name="indexRedirect" type="indexRedirect" />
         <xs:element maxOccurs="unbounded" minOccurs="0" name="include" type="include" />
         <xs:element maxOccurs="unbounded" minOccurs="1" name="article" type="article" />
         <xs:element maxOccurs="1" minOccurs="0" name="chapters" type="chapters" />
         <xs:element maxOccurs="unbounded" minOccurs="1" name="articleID" type="articleID" />
         <xs:element maxOccurs="unbounded" minOccurs="0" name="ref" type="ref" />
         <xs:element maxOccurs="1" minOccurs="0" name="customSearch" type="customSearch" />
      </xs:sequence>
      <xs:attribute name="index" type="xs:anyURI"/>
      <xs:attribute name="glossary" type="xs:anyURI" />
      <xs:attribute name="fullTextSearch" type="xs:anyURI" />
      <xs:attribute name="searchLimit" type="xs:integer"  />
      <xs:attribute name="searchCompressed" type="xs:boolean" />
      <xs:attribute name="helpFormat" type="helpFormat" />
      <xs:attribute name="customSearch" type="xs:boolean" default="false" />
   </xs:complexType>
   <xs:element name="database" type="database" />
   <xs:complexType name="styleSheetTheme">
      <xs:attribute name="styleSheet" type="xs:anyURI" use="required" />
      <xs:attribute name="id" type="xs:string" use="required" />
   </xs:complexType>    
   <xs:complexType name="indexRedirect">
      <xs:attribute name="referTo" type="xs:string" use="required" />
   </xs:complexType>   
   <xs:complexType name="include">
      <xs:attribute name="url" type="xs:anyURI" />
   </xs:complexType>
   <xs:complexType name="article">
      <xs:sequence>
         <xs:element maxOccurs="unbounded" minOccurs="0" name="altTitle" type="altTitle" />
         <xs:element maxOccurs="unbounded" minOccurs="0" name="title" type="title" />
         <xs:element maxOccurs="unbounded" minOccurs="0" name="anchor" type="title" />
      </xs:sequence>
      <xs:attribute name="name" type="xs:string" use="required"/>
      <xs:attribute name="url" type="xs:anyURI" />
   </xs:complexType>
   <xs:complexType name="altTitle">
      <xs:attribute name="name" type="xs:string" use="required"/>
   </xs:complexType>
   <xs:complexType name="title">
      <xs:attribute name="name" type="xs:string" use="required"/>
      <xs:attribute name="id" type="xs:string" use="required"/>
   </xs:complexType>
   <xs:complexType name="chapters">
      <xs:sequence>
         <xs:element maxOccurs="unbounded" minOccurs="0" name="chapter" type="chapter" />
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="chapter">
      <xs:sequence>
         <xs:element maxOccurs="unbounded" minOccurs="0" name="chapter" type="chapter" />
         <xs:element maxOccurs="unbounded" minOccurs="0" name="articleID" type="articleID" />
      </xs:sequence>
      <xs:attribute name="name" type="xs:string" use="required"/>
   </xs:complexType>
   <xs:complexType name="articleID">
      <xs:attribute name="id" type="xs:string" use="required"/>
   </xs:complexType>
   <xs:complexType name="ref">
      <xs:attribute name="id" type="xs:string" use="required"/>
      <xs:attribute name="article" type="xs:string" use="required"/>
      <xs:attribute name="articlePackage" type="xs:string"/>    
      <xs:attribute name="title" type="xs:string"/>
      <xs:attribute name="header" type="xs:string"/>
   </xs:complexType>
   <xs:complexType name="articleSearch">
      <xs:attribute name="name" type="xs:string" use="required"/>
      <xs:attribute name="searchName" type="xs:string" />
      <xs:attribute name="categoryName" type="xs:string" use="required"/>
   </xs:complexType>   
   <xs:complexType name="anchorSearch">
      <xs:attribute name="articleName" type="xs:string" use="required"/>
      <xs:attribute name="name" type="xs:string" use="required"/>
      <xs:attribute name="searchName" type="xs:string" />
      <xs:attribute name="categoryName" type="xs:string" use="required"/>
   </xs:complexType>      
   <xs:complexType name="customSearch">
      <xs:sequence>
         <xs:element maxOccurs="unbounded" minOccurs="0" name="articleSearch" type="articleSearch" />
         <xs:element maxOccurs="unbounded" minOccurs="0" name="anchorSearch" type="anchorSearch" />
      </xs:sequence>
   </xs:complexType>   
</xs:schema>