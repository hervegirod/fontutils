<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
   <xs:simpleType name="infoboxPropertyType">
      <xs:restriction base="xs:string">
         <xs:enumeration value="text"/>
         <xs:enumeration value="url"/>
         <xs:enumeration value="image"/>
      </xs:restriction>
   </xs:simpleType>   
   <xs:complexType name="infoboxDefType">
      <xs:choice maxOccurs="unbounded" minOccurs="1" >
         <xs:element name="property" type="propertyType" />
         <xs:element name="enumProperty" type="enumPropertyType" />
      </xs:choice>       
      <xs:attribute name="id" type="xs:string" use="required" />
   </xs:complexType>  
   <xs:complexType name="enumPropertyType">    
      <xs:sequence maxOccurs="unbounded" minOccurs="1" >
         <xs:element name="state" type="stateType" />
      </xs:sequence>             
      <xs:attribute name="key" type="xs:string" use="required"/>
      <xs:attribute name="keyRef" type="xs:string" />
      <xs:attribute name="keyRefPackage" type="xs:string" />
      <xs:attribute name="defaultState" type="xs:string" />      
      <xs:attribute name="desc" type="xs:string" />
   </xs:complexType>
   <xs:complexType name="stateType">      
      <xs:attribute name="value" type="xs:string" use="required"/>
      <xs:attribute name="desc" type="xs:string" />
   </xs:complexType>            
   <xs:complexType name="propertyType">      
      <xs:attribute name="key" type="xs:string" use="required"/>
      <xs:attribute name="type" type="infoboxPropertyType" />
      <xs:attribute name="keyRef" type="xs:string" />
      <xs:attribute name="keyRefPackage" type="xs:string" />
      <xs:attribute name="desc" type="xs:string" />
   </xs:complexType>   
   <xs:element name="infoboxDefinition" type="infoboxDefType" />   
</xs:schema>
