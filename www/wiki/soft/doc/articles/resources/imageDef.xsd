<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">  
   <xs:simpleType name="color">
      <xs:restriction base="xs:token">
         <xs:pattern value="#[0-9a-fA-F]{6}"/>
      </xs:restriction>
   </xs:simpleType>   
   <xs:simpleType name="size">
      <xs:restriction base="xs:string">
         <xs:pattern value="[0-9]+"/>
         <xs:pattern value="[0-9]+px"/>
         <xs:pattern value="[0-9]+%"/>
      </xs:restriction>
   </xs:simpleType>   
   <xs:simpleType name="marginType">
      <xs:restriction base="xs:string">
         <xs:enumeration value="no"/>
         <xs:enumeration value="noMargin"/>
         <xs:enumeration value="small"/>
         <xs:enumeration value="large"/>
         <xs:enumeration value="false"/>
         <xs:enumeration value="true"/>
      </xs:restriction>
   </xs:simpleType>     
   <xs:element name="images">
      <xs:complexType>
         <xs:choice maxOccurs="unbounded" minOccurs="0" >
            <xs:element name="category" type="category" />
            <xs:element ref="image" />
         </xs:choice>
         <xs:attribute name="version" type="xs:string" />
         <xs:attribute name="date" type="xs:string" />
      </xs:complexType>
   </xs:element>
   <xs:complexType name="category">
      <xs:choice maxOccurs="unbounded" minOccurs="0" >
         <xs:element name="category" type="category" />
         <xs:element ref="image" />
      </xs:choice>      
      <xs:attribute name="desc" type="xs:string" />
   </xs:complexType>   
   <xs:complexType name="image">
      <xs:attribute name="version" type="xs:string" />
      <xs:attribute name="date" type="xs:string" />
      <xs:attribute name="id" type="xs:string" use="required" />
      <xs:attribute name="url" type="xs:anyURI" use="required" />
      <xs:attribute name="transparent" type="xs:boolean" />
      <xs:attribute name="transparentColor" type="color" />
      <xs:attribute name="desc" type="xs:string" />
      <xs:attribute name="width" type="size" />
      <xs:attribute name="height" type="size" />      
      <xs:attribute name="margin" type="marginType" />
   </xs:complexType>
   <xs:element name="image" type="image"/> 
</xs:schema>