<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">      
   <xs:complexType  name="customSearch">
      <xs:sequence>
         <xs:element maxOccurs="unbounded" minOccurs="0" name="category" type="category" />
      </xs:sequence>
      <xs:attribute name="version" type="xs:string" />
      <xs:attribute name="date" type="xs:string" />
      <xs:attribute name="defaultCategory" type="xs:string" />
      <xs:attribute name="includeArticles" type="xs:boolean" />      
   </xs:complexType>
   <xs:complexType name="category">
      <xs:attribute name="name" type="xs:string" use="required" />
   </xs:complexType>
   <xs:element name="customSearch" type="customSearch"/> 
</xs:schema>
